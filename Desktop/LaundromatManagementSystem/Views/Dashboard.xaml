<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:LaundromatManagementSystem.Views"
             x:Class="LaundromatManagementSystem.Views.Dashboard">

    <Grid RowDefinitions="Auto, *">

        <!-- Customer Header -->
        <views:CustomerHeader Grid.Row="0" />

        <!-- Main Content -->
        <Grid Grid.Row="1"
              ColumnDefinitions="7*, 3*"
              ColumnSpacing="24"
              Padding="24"
              BackgroundColor="White">

            <!-- Left Panel - Services -->
            <Border Grid.Column="0"
                    StrokeThickness="0"
                    Padding="0">
                <views:ServiceGrid x:Name="ServiceGridView" />
            </Border>

            <!-- Right Panel - Shopping Cart -->
            <Border Grid.Column="1"
                    StrokeThickness="0"
                    Padding="0">
                <views:ShoppingCart x:Name="ShoppingCart" />
            </Border>

        </Grid>

        <!-- Payment Modal -->
        <Border Grid.RowSpan="2"
                BackgroundColor="#80000000"
                IsVisible="False"
                VerticalOptions="Fill"
                HorizontalOptions="Fill"
                x:Name="PaymentModalOverlay">

            <Border VerticalOptions="Center"
                    HorizontalOptions="Center">
                <views:PaymentModal x:Name="PaymentModalView" />
            </Border>

        </Border>

    </Grid>
</ContentPage>