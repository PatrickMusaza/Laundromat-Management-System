<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LaundromatManagementSystem.Views.ServiceGrid"
             x:Name="ServiceGridView">
    
    <Grid RowDefinitions="Auto, *">
        
        <!-- Category Tabs -->
        <Grid Grid.Row="0"
              ColumnDefinitions="*, *, *, *"
              ColumnSpacing="12"
              Margin="0,0,0,24">
            
            <!-- WASH Button -->
            <Border x:Name="WashButton"
                    BackgroundColor="#1E3A8A"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 8,8,8,8"
                    HeightRequest="64">
                <Label Text="WASH"
                       FontSize="14"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnWashTapped" />
                </Border.GestureRecognizers>
            </Border>
            
            <!-- DRY Button -->
            <Border x:Name="DryButton"
                    Grid.Column="1"
                    BackgroundColor="White"
                    Stroke="#E5E7EB"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 8,8,8,8"
                    HeightRequest="64">
                <Label Text="DRY"
                       FontSize="14"
                       FontAttributes="Bold"
                       TextColor="#6B7280"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnDryTapped" />
                </Border.GestureRecognizers>
            </Border>
            
            <!-- ADD-ON Button -->
            <Border x:Name="AddonButton"
                    Grid.Column="2"
                    BackgroundColor="White"
                    Stroke="#E5E7EB"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 8,8,8,8"
                    HeightRequest="64">
                <Label Text="ADD-ON"
                       FontSize="14"
                       FontAttributes="Bold"
                       TextColor="#6B7280"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnAddonTapped" />
                </Border.GestureRecognizers>
            </Border>
            
            <!-- PACKAGE Button -->
            <Border x:Name="PackageButton"
                    Grid.Column="3"
                    BackgroundColor="White"
                    Stroke="#E5E7EB"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 8,8,8,8"
                    HeightRequest="64">
                <Label Text="PACKAGE"
                       FontSize="14"
                       FontAttributes="Bold"
                       TextColor="#6B7280"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnPackageTapped" />
                </Border.GestureRecognizers>
            </Border>
            
        </Grid>
        
        <!-- Services Grid -->
        <CollectionView Grid.Row="1"
                        x:Name="ServicesCollection"
                        SelectionMode="None">
            
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical"
                                 Span="3"
                                 HorizontalItemSpacing="24"
                                 VerticalItemSpacing="24" />
            </CollectionView.ItemsLayout>
            
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Stroke="#E5E7EB"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 16,16,16,16"
                            BackgroundColor="White"
                            HeightRequest="280"
                            Padding="24">
                        
                        <VerticalStackLayout Spacing="16">
                            
                            <!-- Icon -->
                            <Border BackgroundColor="#FEE2E2"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 100,100,100,100"
                                    WidthRequest="88"
                                    HeightRequest="88"
                                    HorizontalOptions="Center">
                                <Label Text="🔥"
                                       FontSize="48"
                                       TextColor="#EF4444"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>
                            
                            <!-- Service Name -->
                            <Label Text="{Binding Name}"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="#111827"
                                   HorizontalOptions="Center"
                                   HorizontalTextAlignment="Center" />
                            
                            <!-- Description -->
                            <Label Text="{Binding Description}"
                                   FontSize="12"
                                   TextColor="#6B7280"
                                   HorizontalOptions="Center"
                                   HorizontalTextAlignment="Center"
                                   IsVisible="{Binding HasDescription}" />
                            
                            <!-- Price -->
                            <Border BackgroundColor="#F59E0B"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 8,8,8,8"
                                    Padding="16,12">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="{Binding Price, StringFormat='{0:N0}'}"
                                           FontSize="24"
                                           FontAttributes="Bold"
                                           TextColor="White"
                                           HorizontalOptions="Center" />
                                    <Label Text="RWF"
                                           FontSize="12"
                                           TextColor="White"
                                           HorizontalOptions="Center" />
                                </VerticalStackLayout>
                            </Border>
                            
                            <!-- Tap to add -->
                            <Label Text="Tap to add"
                                   FontSize="12"
                                   TextColor="#6B7280"
                                   HorizontalOptions="Center" />
                            
                        </VerticalStackLayout>
                        
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnServiceTapped" 
                                                  CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>
                        
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            
        </CollectionView>
        
    </Grid>
</ContentView>