<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LaundromatManagementSystem.Views.ShoppingCart"
             x:Name="ShoppingCartView">
    
    <Border Stroke="#E5E7EB"
            StrokeThickness="1"
            StrokeShape="RoundRectangle 12"
            BackgroundColor="White"
            Padding="16">
        
        <Grid RowDefinitions="Auto, *, Auto, Auto">
            
            <!-- Header -->
            <Border Grid.Row="0"
                    Stroke="#E5E7EB"
                    StrokeThickness="1"
                    Padding="0,0,0,12"
                    Margin="0,0,0,16">
                
                <HorizontalStackLayout Spacing="8"
                                       VerticalOptions="Center">
                    <Label Text="🛒"
                           FontSize="24" />
                    <Label Text="Shopping Cart"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="#1E3A8A" />
                </HorizontalStackLayout>
                
            </Border>
            
            <!-- Cart Items -->
            <CollectionView Grid.Row="1"
                            x:Name="CartItemsCollection"
                            SelectionMode="None"
                            VerticalScrollBarVisibility="Always">
                
                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center"
                                         VerticalOptions="Center"
                                         Spacing="16">
                        <Label Text="🛒"
                               FontSize="48"
                               HorizontalOptions="Center" />
                        <Label Text="Your cart is empty"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#6B7280"
                               HorizontalOptions="Center" />
                        <Label Text="Add services to get started"
                               FontSize="14"
                               TextColor="#9CA3AF"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Stroke="#E5E7EB"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 8,8,8,8"
                                BackgroundColor="#F9FAFB"
                                Padding="12"
                                Margin="0,0,0,8">
                            
                            <Grid RowDefinitions="Auto, Auto"
                                  ColumnDefinitions="*, Auto">
                                
                                <!-- Item Name and Price -->
                                <VerticalStackLayout Grid.Row="0"
                                                     Grid.Column="0"
                                                     Grid.RowSpan="2">
                                    <Label Text="{Binding Name}"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           TextColor="#111827" />
                                    <Label Text="{Binding Price, StringFormat='{0:N0} RWF'}"
                                           FontSize="12"
                                           TextColor="#F59E0B"
                                           Margin="0,4,0,0" />
                                </VerticalStackLayout>
                                
                                <!-- Remove Button -->
                                <Border Grid.Row="0"
                                        Grid.Column="1"
                                        BackgroundColor="#EF4444"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 4,4,4,4"
                                        WidthRequest="30"
                                        HeightRequest="30">
                                    <Label Text="×"
                                           FontSize="16"
                                           FontAttributes="Bold"
                                           TextColor="White"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center" />
                                    
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnRemoveItemTapped"
                                                              CommandParameter="{Binding Id}" />
                                    </Border.GestureRecognizers>
                                </Border>
                                
                                <!-- Quantity and Total -->
                                <HorizontalStackLayout Grid.Row="1"
                                                       Grid.Column="1"
                                                       Spacing="16"
                                                       VerticalOptions="Center">
                                    
                                    <!-- Quantity -->
                                    <HorizontalStackLayout Spacing="8">
                                        <Label Text="Qty:"
                                               FontSize="12"
                                               TextColor="#6B7280" />
                                        <Label Text="{Binding Quantity}"
                                               FontSize="14"
                                               FontAttributes="Bold"
                                               TextColor="#111827" />
                                    </HorizontalStackLayout>
                                    
                                    <!-- Total -->
                                    <Label Text="{Binding TotalPrice, StringFormat='{0:N0} RWF'}"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           TextColor="#111827" />
                                    
                                </HorizontalStackLayout>
                                
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
            
            <!-- Totals Section -->
            <Border Grid.Row="2"
                    Stroke="#E5E7EB"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 8,8,8,8"
                    BackgroundColor="#F9FAFB"
                    Padding="16"
                    Margin="0,16,0,16"
                    x:Name="TotalsSection"
                    IsVisible="False">
                
                <VerticalStackLayout Spacing="8">
                    
                    <Grid ColumnDefinitions="*, Auto">
                        <Label Grid.Column="0"
                               Text="Subtotal:"
                               FontSize="14"
                               TextColor="#6B7280" />
                        <Label Grid.Column="1"
                               Text="0 RWF"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#111827"
                               x:Name="SubtotalLabel" />
                    </Grid>
                    
                    <Grid ColumnDefinitions="*, Auto">
                        <Label Grid.Column="0"
                               Text="Tax (10%):"
                               FontSize="14"
                               TextColor="#6B7280" />
                        <Label Grid.Column="1"
                               Text="0 RWF"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#111827"
                               x:Name="TaxLabel" />
                    </Grid>
                    
                    <BoxView HeightRequest="1"
                             BackgroundColor="#E5E7EB"
                             Margin="0,8" />
                    
                    <Grid ColumnDefinitions="*, Auto">
                        <Label Grid.Column="0"
                               Text="TOTAL:"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="#1E3A8A" />
                        <Label Grid.Column="1"
                               Text="0 RWF"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="#1E3A8A"
                               x:Name="TotalLabel" />
                    </Grid>
                    
                </VerticalStackLayout>
                
            </Border>
            
            <!-- Process Payment Button -->
            <Button Grid.Row="3"
                    Text="PROCESS PAYMENT"
                    BackgroundColor="#F59E0B"
                    TextColor="White"
                    FontSize="16"
                    FontAttributes="Bold"
                    HeightRequest="64"
                    CornerRadius="8"
                    Clicked="OnProcessPaymentClicked"
                    x:Name="ProcessPaymentButton"
                    IsVisible="False" />
            
        </Grid>
        
    </Border>
    
</ContentView>